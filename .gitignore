# Rust build artifacts (~1.8 GB)
/target

# Local game state + per-callsign identity keys — NEVER publish these
/saves

# Demo-reel screenshots, regenerated by `--demo`. (Curated stills for the README
# live in media/ and ARE tracked.)
/shots

# Local audio renders only. The shipped game synthesises ALL music + SFX in Rust
# at runtime (crates/client/src/{synth,music}.rs) — no audio files are committed.
# These patterns just keep stray `--render-music` / `--render-stems` /
# `--render-title` bounces out of the repo.
/background_track.wav
/MASTER_MIX.wav
/stem_*.wav
/stems_rust/
/ironvein_music.wav
/ironvein_title.wav

# Vendored macroquad bundle backup
js/*.bak.js

# Scratch / temp
*.tmp
*.iv.tmp
.DS_Store

# Claude Code local settings (personal, not shared)
.claude/settings.local.json
