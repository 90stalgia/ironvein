# Rust build artifacts (~1.8 GB)
/target

# Local game state + per-callsign identity keys — NEVER publish these
/saves

# Demo-reel screenshots, regenerated by `--demo`
/shots

# The 158 MB uncompressed soundtrack exceeds GitHub's 100 MB file limit.
# The browser plays background_track.ogg; the native build finds this .wav
# locally if present. (The small sfx_*.wav files ARE tracked — the browser
# needs them.)
/background_track.wav

# Vendored macroquad bundle backup
js/*.bak.js

# Scratch / temp
*.tmp
*.iv.tmp
.DS_Store

# Claude Code local settings (personal, not shared)
.claude/settings.local.json
